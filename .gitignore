# Note that Django collected static files are copies of source files
# from STATICFILES_DIRS and app 'static/' dirs; they are not the originals.
# We will ignore the collected static files.
# We will not ignore app 'static/' dirs.

# ========================
# 1. Python artifacts
# ========================
# Byte-compiled / optimized / DLL files
.mypy_cache/
__pycache__/
*$py.class
*.py.bak
*.py[cod]
.ipynb_checkpoints

# C extensions
*.so

# Distribution / packaging
*.egg-info/
.eggs/
build/
develop-eggs/
dist/
downloads/
eggs/
sdist/
wheels/
*.egg
*.manifest
*.spec
.Python
.installed.cfg

# Installer & pip logs
pip-delete-this-directory.txt
pip-log.txt
pip-selfcheck.json

# ========================
# 2. Test / coverage / reports
# ========================
.hypothesis/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
htmlcov/
*.cover
.cache
.coverage
.coverage.*
coverage.xml
nosetests.xml

# ========================
# 3. Project-specific artifacts
# ========================
# Django logs / local settings / DB
*.log
*.sqlite3
local_settings.py

# Collected static and uploaded media (generated at runtime / mounts)
media/
static/

# Older path (project-specific) — keep for compatibility
src/app/media/

# Downloaded license data and SSL certs used during build
data/certbot/
licenses/

# container logs from local runs
container_logs/

# ========================
# 4. Generated documentation
# ========================
/site/
docs/_build/

# ========================
# 5. Editors
# ========================
.idea/
.vscode/
*.iml
.project
.pydevproject
.ropeproject
.spyderproject
.spyproject
org.eclipse.core.resources.prefs

# ========================
# 6. Misc / OS files
# ========================
.DS_Store

# node modules
node_modules/

# ========================
# 7. Secrets / env
# ========================

# Virtual environments
.venv/
ENV/
env/
venv/
.env
spdx-prod.env

# pyenv
.python-version
